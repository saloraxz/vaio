# =============================================================================
# CSRS — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub — it's in .gitignore.
# =============================================================================

# GitHub repo URL (HTTPS format)
# e.g. https://github.com/yourname/yourrepo.git
GITHUB_REPO=https://github.com/YOUR_USERNAME/YOUR_REPO.git

# GitHub username
GITHUB_USERNAME=YOUR_GITHUB_USERNAME

# GitHub Personal Access Token
# Create at: https://github.com/settings/tokens
# Needs: repo (read + write)
GITHUB_TOKEN=ghp_XXXXXXXXXXXXXXXXXXXX

# Admin interface credentials (port 8001, Tailscale-only)
# Pick something strong — this is the only thing between
# someone on your tailnet and your data
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_to_something_strong

# Secret key for CSRF tokens — generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_SECRET_KEY=GENERATE_A_RANDOM_64_CHAR_HEX_STRING
