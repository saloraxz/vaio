FROM python:3.12-slim

WORKDIR /app

COPY requirements.admin.txt .
RUN pip install --no-cache-dir -r requirements.admin.txt

COPY admin_main.py .
COPY admin_frontend/ admin_frontend/

ENV CSRS_DATA_FILE=/data/data.save
ENV BATCH_LOG_FILE=/data/batch_import.log
ENV ADMIN_FRONTEND_DIR=/app/admin_frontend

EXPOSE 8001

CMD ["uvicorn", "admin_main:app", "--host", "0.0.0.0", "--port", "8001"]
