{
    auto_https off
}

http://saloraxz.com, http://www.saloraxz.com {

    handle_path /api/console* {
        reverse_proxy localhost:5000
    }

    handle /api/* {
        reverse_proxy csrs-web:8000
    }

    # Nextcloud
    handle_path /nextcloud* {
        reverse_proxy nextcloud-app:80 {
            header_up Host {http.request.host}
            header_up X-Real-IP {http.request.remote}
            header_up X-Forwarded-For {http.request.remote}
            header_up X-Forwarded-Proto {http.request.scheme}
        }
    }

    handle_path /csrs* {
        reverse_proxy csrs-web:8000
    }

    handle = /version.txt {
        root * /srv/repo/current/www
        header Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
        header Pragma "no-cache"
        header Expires "0"
        file_server
    }

    # Catch-all standard files
    handle {
        root * /srv/repo/current/www
        file_server
    }

    redir /.well-known/carddav /nextcloud/remote.php/dav/ 301
    redir /.well-known/caldav /nextcloud/remote.php/dav/ 301
}

https://fedoralap.tail055b0e.ts.net {
    tls /certs/fedoralap.tail055b0e.ts.net.crt /certs/fedoralap.tail055b0e.ts.net.key

    handle_path /api/console* {
        reverse_proxy localhost:5000
    }

    handle /api/* {
        reverse_proxy csrs-web:8000
    }

    handle_path /nextcloud* {
        reverse_proxy nextcloud-app:80 {
            header_up Host {http.request.host}
            header_up X-Real-IP {http.request.remote}
            header_up X-Forwarded-For {http.request.remote}
            header_up X-Forwarded-Proto {http.request.scheme}
        }
    }

    handle_path /csrs* {
        reverse_proxy csrs-web:8000
    }

    handle = /version.txt {
        root * /srv/repo/current/www
        header Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
        header Pragma "no-cache"
        header Expires "0"
        file_server
    }

    handle {
        root * /srv/repo/current/www
        file_server
    }

    redir /.well-known/carddav /nextcloud/remote.php/dav/ 301
    redir /.well-known/caldav /nextcloud/remote.php/dav/ 301
}


# ntfy Dashboard
http://ntfy.saloraxz.com:8080 {
    reverse_proxy ntfy:80
}
