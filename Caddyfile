# 1. Main Website (Port 443)
# We keep the domain here so Caddy uses your Tailscale certs
fedoralap.tail055b0e.ts.net {
    tls /certs/fedoralap.tail055b0e.ts.net.crt /certs/fedoralap.tail055b0e.ts.net.key
    root * /var/www/html/current/www
    route {
        rewrite /ntfy /ntfy.html
        file_server
    }
}

# 2. ntfy (Port 8080)
# We use ':8080' so Caddy accepts both HTTP (from Funnel) and HTTPS
:8080 {
    reverse_proxy ntfy:80
}