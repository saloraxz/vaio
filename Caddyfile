# Main Website (Secure)
fedoralap.tail055b0e.ts.net {
    tls /certs/fedoralap.tail055b0e.ts.net.crt /certs/fedoralap.tail055b0e.ts.net.key
    root * /var/www/html/current/www
    route {
        rewrite /ntfy /ntfy.html
        file_server
    }
}

# The fix: Remove the "http://" prefix so Caddy can automatically
